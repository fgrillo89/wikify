# LLM provider credentials
# Use whichever provider matches your litellm model ids.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default writing / balanced tier
# SCHOLARFORGE_LLM_MODEL=claude-sonnet-4-20250514

# Fast extraction tier
# SCHOLARFORGE_LLM_FAST_MODEL=claude-haiku-4-5-20251001

# Optional deep / audit tier
# SCHOLARFORGE_LLM_DEEP_MODEL=

# Optional dedicated vision model (falls back to fast tier)
# SCHOLARFORGE_VISION_MODEL=

# Example Codex/OpenAI-style setup:
# OPENAI_API_KEY=sk-...
# SCHOLARFORGE_LLM_MODEL=gpt-5
# SCHOLARFORGE_LLM_FAST_MODEL=gpt-5-mini

{
    "name": "Nature",
    "publisher": "Springer Nature",
    "citation_style": "numbered",
    "word_limit": 5000,
    "abstract_word_limit": 150,
    "required_sections": [
        "Abstract",
        "Introduction",
        "Results",
        "Discussion",
        "Methods"
    ],
    "font_family": "Times New Roman",
    "font_size_pt": 12,
    "line_spacing": 2.0,
    "column_layout": "single",
    "reference_format": "{number}. {authors}. {title}. {journal} {volume}, {pages} ({year}).",
    "figure_min_dpi": 300,
    "notes": "Nature format. Superscript numbered citations. Methods section at end. Abstract is a single paragraph, no heading. Max 50 references.",
    "template_docx": "nature_manuscript.docx"
}

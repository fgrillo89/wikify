{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Figure Table Extraction Result",
  "description": "Structured figure and table extraction output for one unit.",
  "type": "object",
  "required": ["findings"],
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "summary"],
        "additionalProperties": false,
        "properties": {
          "unit_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    }
  }
}

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Data (local, potentially large). Anchored to the repo root so it does not
# also swallow the source package src/wikify/data/.
/data/
*.db

# UV lock
uv.lock

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Archive (legacy code, kept locally)
archive/

# Ruff
.ruff_cache/

# Cache
.cache/
.claude/worktrees/

# Pytest / test fixtures (generated)
.tmp/
logs/

# Benchmark results (generated)
benchmarks/results/

# Notebooks (local exploration, not versioned)
notebooks/

# Scratch (one-off scripts, experiments, not versioned)
scratch/
scratch_*.py
scratch_*.log

# Wikify bundles — runtime build state, regenerated per run
bundles/

# Claude Code local launch config (carries absolute paths)
.claude/launch.json

# Claude Code session state
.claude/scheduled_tasks.lock

# Claude Code MCP server config (carries absolute paths)
.mcp.json

# Vetter and exploration scratch — agent-produced run artifacts
tmp_writes/
/VETTING_REPORT.md
/accepted_ids.txt
/candidates_aggregated.json
/q*.json
/q_*.json

# Repo-root vetter / extractor / debug scratch (one-off, never checked in).
# These are produced by subagents that drop intermediate JSON/TXT in the
# project root during evidence loops. Keep the patterns specific to root
# so subdirectories aren't accidentally ignored.
/evidence_*.json
/evidence_*.txt
/build_evidence_*.txt
/build_evidence_*.json
/_tmp_*
/chunk_*.json
/chunk_*.txt
/corpus_find_result*.json
/payload_*.json
/imc_*.json
/fs_evidence_*.json
/exact_quotes*.txt
/quote_verify*.txt
/final_verify*.txt
/fix_snippets*.txt
/long*.txt
/snippets*.txt
/*_snippet.txt
/*_snippets.txt
/df*_id.txt
# Mis-quoted tool-result paths from Claude harness leaking project root.
# Filenames have a non-printable byte right after the leading ``C`` that
# git status displays as ``\357\200\272`` (octal), so we can't anchor on
# it. Match instead on the distinctive ``.claudeprojectsC--dev-scholarforge``
# substring the harness embeds inside the leaked filenames.
/C*.claudeprojectsC--dev-scholarforge*
